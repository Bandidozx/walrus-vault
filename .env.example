# Walrus Vault Configuration

# Server
NODE_ENV=development
PORT=3000

# Walrus API
WALRUS_API=https://aggregator.walrus.site/v1
WALRUS_PUBLISHER=https://publisher.walrus.site/v1

# Sui Network
SUI_NETWORK=testnet
SUI_RPC=https://fullnode.testnet.sui.io:443

# Tatum API (Optional)
TATUM_API_KEY=your_tatum_api_key_here
TATUM_NETWORK=ethereum-sepolia

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Security
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
